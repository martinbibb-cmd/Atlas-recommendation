{
  "name": "atlas-recommendation",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "wrangler pages dev dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "npm run build && wrangler pages deploy dist",
    "db:migrate:local": "wrangler d1 migrations apply ATLAS_REPORTS_D1 --local",
    "db:migrate:remote": "wrangler d1 migrations apply ATLAS_REPORTS_D1 --remote",
    "db:list": "wrangler d1 migrations list ATLAS_REPORTS_D1"
  },
  "dependencies": {
    "@atlas/contracts": "github:martinbibb-cmd/Atlas-contracts",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@testing-library/dom": "^10.4.1",
    "@types/qrcode": "^1.5.6",
    "dexie": "^4.4.2",
    "konva": "^10.2.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-is": "^19.2.4",
    "react-joyride": "^3.0.0-7",
    "react-konva": "^19.2.3",
    "recharts": "^3.7.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.29.0",
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.5",
    "wrangler": "^4.74.0"
  }
}
