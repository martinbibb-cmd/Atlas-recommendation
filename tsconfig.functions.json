{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "composite": true,
    "types": []
  },
  "include": [
    "functions/**/*.ts",
    "worker-configuration.d.ts",
    "src/engine/**/*.ts",
    "src/contracts/**/*.ts",
    "src/ui/fullSurvey/FullSurveyModelV1.ts"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/__tests__/**"
  ]
}
